#!/usr/bin/env bash
# SessionStart hook for airtable-super-creator plugin
# Injects Airtable skill awareness into every conversation

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Check for API key
api_key_warning=""
if [ -z "${AIRTABLE_ACCESS_TOKEN:-}" ]; then
    api_key_warning="\\n\\n⚠️ **WARNING:** No Airtable access token detected. Run the setup-api-key skill first."
fi

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

api_warning_escaped=$(escape_for_json "$api_key_warning")

session_context="<AIRTABLE_CONTEXT>\nYou have Airtable Super Creator skills available.\n\n**Available Skills** (16 skills, invoke via Skill tool with 'airtable-super-creator:' prefix):\n\n| Skill | Purpose |\n|-------|--------|\n| setup-api-key | Configure Airtable personal access token |\n| user-info | Check authenticated user and token scopes (whoami) |\n| bases | List, create, update, delete bases |\n| tables | Create, list, update tables |\n| fields | Create, update fields (32+ types) |\n| records | Full CRUD + upsert + batch (10/request) |\n| views | Create, list, update, delete views |\n| comments | Record comments with @mention support |\n| webhooks | Real-time change notifications (7-day expiry) |\n| collaborators | Base and workspace access management |\n| workspaces | Workspace creation, deletion, base moves |\n| interfaces | Interface listing and sharing |\n| attachments | File upload to records (content.airtable.com) |\n| automations | Automation design and scripting |\n| sync | Data sync pipelines and upsert patterns |\n| enterprise | Enterprise user/audit management |\n\n**Agents** (1 orchestrator + 7 specialized):\n- airtable-creator: Main orchestrator - routes to sub-agents\n- airtable-base-architect: Schema design, base creation, data modeling\n- airtable-record-ops: Bulk imports, migrations, batch CRUD\n- airtable-field-manager: Field types, formulas, rollups, lookups\n- airtable-interface-builder: Interface sharing and access management\n- airtable-admin: Enterprise, workspaces, webhooks, security\n- airtable-schema-designer: Quick schema design from requirements\n- airtable-data-manager: Data operations\n\n**Workflow:** setup-api-key → bases → tables → fields → records → views\n\n**Key details:**\n- Base URL: https://api.airtable.com/v0\n- Content URL: https://content.airtable.com/v0 (attachments)\n- Rate limits: 5 req/sec per base, 50 across all bases\n- Batch size: 10 records per create/update/delete call\n- Auth: Bearer token (personal access token starting with 'pat')\n- Webhooks expire in 7 days (must refresh)\n\n**REQUIRED:** Always invoke the relevant skill via the Skill tool. Never guess Airtable API payloads from memory.${api_warning_escaped}\n</AIRTABLE_CONTEXT>"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
