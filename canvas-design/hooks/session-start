#!/usr/bin/env bash
# SessionStart hook for canvas-design plugin
# Injects Canvas Design v3 skill awareness into every conversation

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

session_context="<CANVAS_DESIGN_CONTEXT>\nYou have Canvas Design v3 skills available for generating visual designs.\n\n**Rendering Modes:**\n- HTML/CSS + Playwright (PRIMARY) — covers, posters, social media, thumbnails, brand assets\n- PIL/Pillow (SECONDARY) — abstract/generative art only\n\n**Available Skills** (8 skills, invoke via Skill tool with 'canvas-design:' prefix):\n\n| Skill | Renderer | Purpose |\n|-------|----------|---------|\n| html-design | HTML/CSS | Core design patterns, CSS techniques, rendering pipeline |\n| cover-design | HTML/CSS | GitHub, Notion, LinkedIn, YouTube, Twitter covers |\n| poster-design | HTML/CSS | Event, movie, concert, print posters |\n| social-media-design | HTML/CSS | Instagram, LinkedIn, Twitter, Facebook, Pinterest |\n| thumbnail-design | HTML/CSS | YouTube thumbnails, Open Graph images |\n| abstract-art | PIL | Generative/procedural art with noise, flow fields |\n| brand-assets | HTML/CSS | Logos, icons, brand identity kits |\n| render-engine | Playwright | HTML to PNG rendering pipeline |\n\n**Agents** (1 orchestrator + 4 specialists):\n- design-director: Main orchestrator — routes to specialists and skills\n- layout-architect: Composition, spatial layout, CSS Grid/Flexbox\n- typography-director: Font pairing, type scale, text hierarchy\n- color-specialist: Palette selection, contrast, color harmony\n- render-engineer: Playwright pipeline, font loading, resolution\n\n**Quick Commands:** /quick-cover, /quick-poster, /quick-social, /quick-thumbnail, /quick-abstract, /render-html, /list-fonts, /list-palettes\n\n**Resources:** 80+ bundled fonts · 20 curated palettes · 15 typography pairings · 20+ format presets · 8 composition techniques\n\n**REQUIRED:** Always invoke the relevant skill via the Skill tool. Never guess HTML/CSS patterns from memory.\n</CANVAS_DESIGN_CONTEXT>"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
